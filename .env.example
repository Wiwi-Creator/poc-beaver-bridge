# Comma-separated list of valid API keys
API_KEYS=key-change-me-1,key-change-me-2

# Path to MCP server registry
MCP_REGISTRY_PATH=config/mcp_servers.yaml

# Logging level: DEBUG | INFO | WARNING | ERROR
LOG_LEVEL=INFO

# Environment: development | production
ENVIRONMENT=development

# Tool call rate limit per API key（slowapi 格式）
# 例如 "60/minute"、"10/second"、"1000/hour"
RATE_LIMIT_TOOL_CALL=60/minute

# For local dev: path to GCP service account key JSON
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
